# Copy to apps/web/.env.local and fill in. Never commit .env.local.

# ─── Public app URL ───
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Auth (Clerk — Phase 1 setup, real keys in Phase 1.5) ───
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ─── Database ───
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/sojoai?retryWrites=true&w=majority

# ─── AI ───
ANTHROPIC_API_KEY=sk-ant-...

# ─── Email (Phase 5) ───
RESEND_API_KEY=re_...

# ─── Payments (Phase 6) ───
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
