{
  "name": "sojoai",
  "version": "0.0.0",
  "private": true,
  "description": "Sojo AI — a virtual AI team for builders. Workspace root.",
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "pnpm --filter @sojoai/web dev",
    "build": "pnpm --filter @sojoai/web build",
    "start": "pnpm --filter @sojoai/web start",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8"
  }
}
